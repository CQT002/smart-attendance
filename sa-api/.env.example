# ============================================
# Smart Attendance API - Environment Variables
# Copy file này thành .env và điền giá trị
# ============================================

# App
APP_NAME=SmartAttendance
APP_PORT=8080
APP_ENV=development       # development | production
APP_DEBUG=true
APP_VERSION=1.0.0

# Database (PostgreSQL)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=smart_attendance
DB_USER=postgres
DB_PASSWORD=postgres
DB_SSL_MODE=disable
DB_MAX_OPEN_CONNS=25      # Tối ưu cho 5000 users giờ cao điểm
DB_MAX_IDLE_CONNS=10
DB_CONN_MAX_LIFETIME=300  # 5 phút (giây)

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_POOL_SIZE=10

# JWT
JWT_SECRET=change-me-to-a-strong-secret-in-production
JWT_EXPIRE_HOURS=24
JWT_REFRESH_EXPIRE_DAYS=7
